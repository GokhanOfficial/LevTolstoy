# Server
PORT=3000
NODE_ENV=development
# Maximum source upload size in MB. Media inputs can be up to 1GB; converted audio sent to AI is kept under 100MB.
MAX_FILE_SIZE=1024
MAX_UPLOAD_SIZE_MB=1024

# Media conversion (FFmpeg)
# Leave as command names on Linux/Docker, or set absolute paths if needed.
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
MEDIA_MAX_OUTPUT_SIZE_MB=100
MEDIA_TARGET_OUTPUT_SIZE_MB=95
MEDIA_MIN_AUDIO_BITRATE_KBPS=32
MEDIA_MAX_AUDIO_BITRATE_KBPS=320
MEDIA_OUTPUT_SAMPLE_RATE=44100

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1  # Optional: custom base URL
OPENAI_FILENAME_MODEL=gpt-4o-mini  # Optional: model for filename generation

# S3-compatible storage (Cloudflare R2, AWS S3, MinIO, etc.)
# All files are served through our backend (proxy) for security and rate limiting
# If not configured, files will be stored locally and sent as base64
S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com  # R2 or S3 endpoint
S3_REGION=auto  # 'auto' for R2, region code for AWS (e.g., us-east-1)
S3_ACCESS_KEY_ID=your_access_key_id
S3_SECRET_ACCESS_KEY=your_secret_access_key
S3_BUCKET=your_bucket_name

# Google Drive API (OAuth - ONLY for DOCX/PPTX/XLSX → PDF conversion)
# Required only if you need to convert Office documents
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_oauth_client_secret
# GOOGLE_TOKEN is set automatically after running "npm run auth"
